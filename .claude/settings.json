{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; echo \"$f\" | grep -qE '\\.(ts|tsx|js|jsx|json|md|yaml|yml)$' && pnpm exec prettier --write \"$f\" || true; } 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(./.env*)",
      "Read(./**/.env*)",
      "Read(./.*.vars)",
      "Read(./**/.*.vars)",
      "Read(~/.ssh/**)",
      "Read(**/secrets/**)",
      "Bash(git push -u origin main)",
      "Bash(git push main)"
    ],
    "ask": ["Bash(git push)", "Bash(git reset --hard*)", "Bash(docker *)"],
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "mcp__MCP_DOCKER__*"
    ]
  }
}
